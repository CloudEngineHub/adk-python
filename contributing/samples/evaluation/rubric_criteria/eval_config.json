        {
          "rubric_id": "concise",
          "rubric_content": {
            "text_property": "The response is concise and free of filler."
          }
        }
      ]
    },
    "rubric_based_tool_use_quality_v1": {
      "threshold": 1.0,
      "judge_model_options": {"judge_model": "gemini-2.5-flash", "num_samples": 5},
      "rubrics": [
        {
          "rubric_id": "uses_location_filter",
          "rubric_content": {
            "text_property": "When the user names a room, the agent calls list_devices with a matching location filter."
          }
